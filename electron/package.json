{
  "name": "shiru",
  "version": "6.7.2",
  "license": "GPL-3.0-or-later",
  "packageManager": "pnpm@10.34.1",
  "private": true,
  "author": "RockinChaos <RockinChaos@users.noreply.github.com>",
  "description": "Shiru - Kōtai: a fork of Shiru adding TorBox debrid streaming. A personal anime library manager for watching and tracking your collection in real time.",
  "main": "build/main.js",
  "homepage": "https://github.com/Flametossed/Shiru#readme",
  "scripts": {
    "start": "cross-env NODE_ENV=development webpack build && concurrently --kill-others \"npm run web:watch\" \"npm run electron:start\"",
    "web:watch": "webpack serve",
    "web:build": "cross-env NODE_ENV=production webpack build",
    "electron:start": "cross-env NODE_ENV=development electron ./build/main.js",
    "build": "npm run web:build && electron-builder",
    "electron:build": "electron-builder",
    "publish": "npm run web:build && electron-builder -p always"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "common": "workspace:*",
    "client": "workspace:*",
    "electron": "42.3.0",
    "electron-builder": "^26.15.5",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9"
  },
  "dependencies": {
    "@paymoapp/electron-shutdown-handler": "^1.1.3",
    "@xhayper/discord-rpc": "^1.3.4",
    "concurrently": "^10.0.3",
    "jimp": "0.22.12",
    "powertoast": "^3.0.0",
    "utp-native": "^2.5.3"
  },
  "standard": {
    "ignore": [
      "bundle.js",
      "bundle.map.js"
    ],
    "env": [
      "browser",
      "node"
    ]
  }
}
